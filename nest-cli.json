{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/buddy/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/buddy/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/buddy",
  "projects": {
    "buddy": {
      "type": "application",
      "root": "apps/buddy",
      "entryFile": "main",
      "sourceRoot": "apps/buddy/src",
      "compilerOptions": {
        "tsConfigPath": "apps/buddy/tsconfig.app.json"
      }
    },
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "shelves": {
      "type": "application",
      "root": "apps/shelves",
      "entryFile": "main",
      "sourceRoot": "apps/shelves/src",
      "compilerOptions": {
        "tsConfigPath": "apps/shelves/tsconfig.app.json"
      }
    },
    "spaces": {
      "type": "application",
      "root": "apps/spaces",
      "entryFile": "main",
      "sourceRoot": "apps/spaces/src",
      "compilerOptions": {
        "tsConfigPath": "apps/spaces/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}